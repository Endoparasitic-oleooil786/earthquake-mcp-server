{
  "name": "@cyanheads/earthquake-mcp-server",
  "version": "0.1.8",
  "description": "Search USGS and EMSC seismic data — real-time feeds, event queries, and earthquake counts via MCP. STDIO or Streamable HTTP.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/earthquake-mcp-server#readme",
  "repository": "https://github.com/cyanheads/earthquake-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "@cyanheads/earthquake-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/earthquake-mcp-server", "run", "start:stdio"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
